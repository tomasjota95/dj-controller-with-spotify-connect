# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# SPOTIFY_CLIENT_ID: Required for Spotify Web API search and streaming.
# Users can fetch this from the Spotify Developer Dashboard.
SPOTIFY_CLIENT_ID=YOUR_SPOTIFY_CLIENT_ID

# SPOTIFY_CLIENT_SECRET: Corresponding client secret for the Spotify Developer App.
SPOTIFY_CLIENT_SECRET=YOUR_SPOTIFY_CLIENT_SECRET

